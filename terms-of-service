		// Function to initialize Crisp with user data
		window.initCrispUser = async function() {
			// Get the required cookies
			const cookies = document.cookie.split('; ').reduce((acc, curr) => {
				const [key, value] = curr.split('=');
				acc[key] = value;
				return acc;
			}, {});
			const xsrfToken = cookies['XSRF-TOKEN'];
			const upstreamSession = cookies['upstream_session'];
			if (!xsrfToken || !upstreamSession) {
				console.debug('Missing required cookies');
				return;
			}
			try {
				const response = await fetch('https://studio.upstream.so/me', {
					credentials: 'include',
					headers: {
						'Accept': 'application/json',
						'X-XSRF-TOKEN': decodeURIComponent(xsrfToken),
						'X-Requested-With': 'XMLHttpRequest',
						'Content-Type': 'application/json',
					},
				});
				const data = await response.json();
				if (!response.ok) {
					throw new Error(`HTTP error! status: ${response.status}`);
				}
				if (data) {
					const user = data;
					let nickName = user.name;
					if (user.has_active_subscription) {
						nickName = `${user.name} (SUB)`;
					}
					window.CRISP_TOKEN_ID = `${user.email}-${user.id}`;
					window.$crisp.push(['set', 'user:nickname', nickName]);
					window.$crisp.push(['set', 'user:email', user.email]);
					window.$crisp.push([
						'set',
						'session:data',
						[
							[
								['id', user.id],
								['plan', user.plan_name],
								['max_streams', user.max_streams],
								['streams_running', user.streams_running],
								[
									'trial_period',
									user.trail_period === null ?
									'Is subscriber' :
									user.trail_period,
								],
							],
						],
					]);
					console.debug('Crisp user data updated successfully');
					return data;
				}
			} catch (error) {
				console.error('Failed to initialize Crisp user:', error);
				throw error;
			}
		};
		// Auto-initialize on page load
		initCrispUser().catch(console.error);
	</script>
